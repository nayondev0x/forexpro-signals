# ═════════════════════════════════════════
# ForexPro Signals - Environment Variables
# Copy this to .env.local and fill in your keys
# ═════════════════════════════════════════

# Twelve Data RapidAPI - Key 1
TWELVE_DATA_API_KEY=your_rapidapi_key_1
TWELVE_DATA_API_HOST=twelve-data1.p.rapidapi.com

# Twelve Data RapidAPI - Key 2 (backup for rate limit rotation)
TWELVE_DATA_API_KEY_2=your_rapidapi_key_2
TWELVE_DATA_API_HOST_2=twelve-data1.p.rapidapi.com

# Alpha Vantage RapidAPI - Key 1
ALPHA_VANTAGE_API_KEY=your_rapidapi_key_1
ALPHA_VANTAGE_API_HOST=alpha-vantage.p.rapidapi.com

# Alpha Vantage RapidAPI - Key 2 (backup for rate limit rotation)
ALPHA_VANTAGE_API_KEY_2=your_rapidapi_key_2
ALPHA_VANTAGE_API_HOST_2=alpha-vantage.p.rapidapi.com

# Trader Calendar API (Economic Calendar)
TRADER_CALENDAR_API_KEY=your_rapidapi_key
TRADER_CALENDAR_API_HOST=trader-calendar.p.rapidapi.com

# Breaking News API (Market News)
BREAKING_NEWS_API_KEY=your_rapidapi_key
BREAKING_NEWS_API_HOST=myallies-breaking-news-v1.p.rapidapi.com

# Stock Prices API (US Stocks)
STOCK_PRICES_API_KEY=your_rapidapi_key
STOCK_PRICES_API_HOST=stock-prices2.p.rapidapi.com

# TradingEconomics Calendar API (Primary, richer data)
TRADEDECONOMICS_API_KEY=your_rapidapi_key
TRADEDECONOMICS_API_HOST=economic-calendar-api-tradingeconomics.p.rapidapi.com

# SelfTrade Crypto API (Signals, Funding Rates, Fear & Greed)
SELFTRADE_API_KEY=your_rapidapi_key
SELFTRADE_API_HOST=selftrade.p.rapidapi.com

# Crypto Technical Analysis API (15 Indicators: RSI, MACD, ADX, Bollinger, etc.)
CRYPTO_TA_API_KEY=your_rapidapi_key
CRYPTO_TA_API_HOST=crypto-technical-analysis-indicator-apis-for-trading.p.rapidapi.com

# Binance Real-Time Data API (Trades, Depth, Klines, Ticker, Order Flow)
BINANCE_API_KEY=your_rapidapi_key
BINANCE_API_HOST=real-time-binance-data.p.rapidapi.com

# CryptoEdge Market Sentiment (Crowding Score, Signals, Alerts, Context)
CRYPTOEDGE_API_KEY=your_rapidapi_key
CRYPTOEDGE_API_HOST=cryptoedge-market-sentiment-indicators.p.rapidapi.com

# Forex Signals API (Raw Forex Signals + MT Auth)
FOREX_SIGNALS_API_KEY=your_rapidapi_key
FOREX_SIGNALS_API_HOST=forex-signals-api.p.rapidapi.com

# Finviz Data API (Screener, News, Insider, Forex, Futures, Groups, Map, Autocomplete, Quote)
FINVIZ_API_KEY=your_rapidapi_key
FINVIZ_API_HOST=finviz-data-api.p.rapidapi.com

# FinanceCore API (Crypto, Market, Stock, Convert)
FINANCECORE_API_KEY=your_rapidapi_key
FINANCECORE_API_HOST=financecore-api.p.rapidapi.com

# Technical Signals API (35 AI Agents Voting on Stocks)
TECHNICAL_SIGNALS_API_KEY=your_rapidapi_key

# Traders Hub API (Stock News Sentiment + Multi-Timeframe Analysis)
TRADERS_HUB_API_KEY=your_rapidapi_key

# Trade Bloom Finance — Bloomberg Powered (News, Movers, Commodities, Currencies, Key-Stats, Financials, Search)
RAPIDAPI_KEY=your_rapidapi_key

# Twelve Data Keys 3 & 4 (Extended capacity for 8-key rotation)
TWELVE_DATA_API_KEY_3=your_rapidapi_key_3
TWELVE_DATA_API_HOST_3=twelve-data1.p.rapidapi.com
TWELVE_DATA_API_KEY_4=your_rapidapi_key_4
TWELVE_DATA_API_HOST_4=twelve-data1.p.rapidapi.com

# Alpha Vantage Keys 3 & 4 (Extended capacity for 8-key rotation)
ALPHA_VANTAGE_API_KEY_3=your_rapidapi_key_3
ALPHA_VANTAGE_API_HOST_3=alpha-vantage.p.rapidapi.com
ALPHA_VANTAGE_API_KEY_4=your_rapidapi_key_4
ALPHA_VANTAGE_API_HOST_4=alpha-vantage.p.rapidapi.com